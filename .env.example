# Frontend (React)
# Chave publica do Mercado Pago (APP_USR-...)
REACT_APP_MP_PUBLIC_KEY=

# Mercado Pago - Token de acesso da conta (APP_USR-...)
MERCADO_PAGO_ACCESS_TOKEN=

# Opcional: URL base da aplicacao para success_url/cancel_url
APP_BASE_URL=http://localhost:3000

# UID do administrador da pagina (Firebase Authentication)
# Copie de console.firebase.google.com > Authentication > Users
REACT_APP_ADMIN_UID=

# Consulta de CPF (autocompletar nome no cadastro)
# Provedor recomendado: InfoSimples (Receita Federal)
#   CPF_API_URL=https://api.infosimples.com/api/v2/consultas/receita-federal/cpf
#   CPF_API_TOKEN=<seu_token_infosimples>
# Sem essas variaveis o backend retorna fullName=null e o usuario tem que preencher o nome manualmente.
CPF_API_URL=
CPF_API_TOKEN=

# ==== Verificacao de e-mail ====
# Segredo usado para assinar/verificar JWTs do link de confirmacao (qualquer string longa).
EMAIL_VERIFICATION_SECRET=

# Provedor de envio: Resend (https://resend.com)
RESEND_API_KEY=

# Remetente verificado na Resend (precisa ter o dominio validado).
EMAIL_FROM_ADDRESS=no-reply@trabalheila.com.br

# Alternativa SMTP generico (NAO usado pelas rotas atuais, deixado como referencia
# caso voce troque o provedor para nodemailer):
# EMAIL_SERVICE_HOST=smtp.seudominio.com
# EMAIL_SERVICE_PORT=587
# EMAIL_SERVICE_USER=
# EMAIL_SERVICE_PASS=
