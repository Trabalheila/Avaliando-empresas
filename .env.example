# Frontend (React)
# Chave publica do Mercado Pago (APP_USR-...)
REACT_APP_MP_PUBLIC_KEY=

# Mercado Pago - Token de acesso da conta (APP_USR-...)
MERCADO_PAGO_ACCESS_TOKEN=

# Aliases usados pelo fluxo de pagamentos do caso (Ad Exitum). Se preferir,
# mantenha apenas os nomes canonicos acima — o backend usa MERCADO_PAGO_ACCESS_TOKEN.
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=

# Segredo do CRON de lembrete de prazos (Vercel Cron -> /api/cron-prazos).
# Gere uma string aleatoria longa e configure o MESMO valor na Vercel em
# Settings -> Environment Variables. A Vercel envia este valor no header
# Authorization: Bearer <CRON_SECRET> nas execucoes agendadas.
CRON_SECRET=

# Opcional: URL base da aplicacao para success_url/cancel_url
APP_BASE_URL=http://localhost:3000

# UID do administrador da pagina (Firebase Authentication)
# Copie de console.firebase.google.com > Authentication > Users
REACT_APP_ADMIN_UID=

# Consulta de CPF (autocompletar nome no cadastro)
# Provedor recomendado: InfoSimples (Receita Federal)
#   CPF_API_URL=https://api.infosimples.com/api/v2/consultas/receita-federal/cpf
#   CPF_API_TOKEN=<seu_token_infosimples>
# Sem essas variaveis o backend retorna fullName=null e o usuario tem que preencher o nome manualmente.
CPF_API_URL=
CPF_API_TOKEN=

# ==== Verificacao de e-mail ====
# Segredo usado para assinar/verificar JWTs do link de confirmacao (qualquer string longa).
EMAIL_VERIFICATION_SECRET=

# Provedor de envio: Resend (https://resend.com)
RESEND_API_KEY=

# Remetente verificado na Resend (precisa ter o dominio validado).
EMAIL_FROM_ADDRESS=no-reply@trabalheila.com.br

# Alternativa SMTP generico (NAO usado pelas rotas atuais, deixado como referencia
# caso voce troque o provedor para nodemailer):
# EMAIL_SERVICE_HOST=smtp.seudominio.com
# EMAIL_SERVICE_PORT=587
# EMAIL_SERVICE_USER=
# EMAIL_SERVICE_PASS=

# ==== Dados fiscais da plataforma (emissor NFS-e) ====
# Apenas digitos (14)
PLATFORM_CNPJ=67029282000120
PLATFORM_RAZAO_SOCIAL=Trabalhei La
PLATFORM_NOME_FANTASIA=Trabalhei La
PLATFORM_INSCRICAO_MUNICIPAL=
# Codigo IBGE do municipio do prestador (7 digitos). Ex: Sao Paulo=3550308
PLATFORM_CODIGO_MUNICIPIO=
PLATFORM_UF=
# Item da lista de servicos (LC 116/2003). Ex: "1.05" (licenciamento/cessao de uso de software)
PLATFORM_ITEM_LISTA_SERVICO=1.05
# Codigo de tributacao municipal (CTISS / codigo da prefeitura). Confira na prefeitura.
PLATFORM_CODIGO_TRIBUTARIO_MUNICIPIO=
# Aliquota ISS em percentual (ex: 2.0 para 2%)
PLATFORM_ALIQUOTA_ISS=2.0
# ISS retido na fonte? "true" ou "false"
PLATFORM_ISS_RETIDO=false
# Descricao padrao impressa na NFS-e
PLATFORM_DESCRICAO_SERVICO=Assinatura mensal da plataforma Trabalhei La

# ==== Provedor de NFS-e: Focus NFe (https://focusnfe.com.br) ====
# Token de API (use o token de homologacao enquanto estiver validando)
FOCUS_NFE_TOKEN=
# Ambiente: "homologacao" ou "producao"
FOCUS_NFE_ENV=homologacao
# Disparar emissao automatica de NFS-e quando o webhook do Mercado Pago
# receber pagamento aprovado? "true" para habilitar.
NFSE_AUTO_EMIT=false
