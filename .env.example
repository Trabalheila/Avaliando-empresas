# Frontend (React)
# Chave publica do Stripe (comeca com pk_test_ ou pk_live_)
REACT_APP_STRIPE_PUBLISHABLE_KEY=

# Provedor de checkout: stripe (padrao) ou nome customizado para redirecionamento por URL
CHECKOUT_PROVIDER=stripe

# URL de checkout externo quando CHECKOUT_PROVIDER != stripe
# Exemplo: https://checkout.seuprovedor.com/premium
CHECKOUT_EXTERNAL_URL=

# Mercado Pago (quando CHECKOUT_PROVIDER=mercadopago)
# Token de acesso da conta (APP_USR-...)
MERCADO_PAGO_ACCESS_TOKEN=

# API route /api/create-checkout-session
# Chave secreta do Stripe (comeca com sk_test_ ou sk_live_)
STRIPE_SECRET_KEY=

# ID do preco da assinatura premium (comeca com price_)
STRIPE_PRICE_ID_PREMIUM=

# Opcional: URL base da aplicacao para success_url/cancel_url
APP_BASE_URL=http://localhost:3000

# UID do administrador da pagina (Firebase Authentication)
# Copie de console.firebase.google.com > Authentication > Users
REACT_APP_ADMIN_UID=
