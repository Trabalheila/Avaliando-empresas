# Frontend (React)
# Chave publica do Stripe (comeca com pk_test_ ou pk_live_)
REACT_APP_STRIPE_PUBLISHABLE_KEY=

# API route /api/create-checkout-session
# Chave secreta do Stripe (comeca com sk_test_ ou sk_live_)
STRIPE_SECRET_KEY=

# ID do preco da assinatura premium (comeca com price_)
STRIPE_PRICE_ID_PREMIUM=

# Opcional: URL base da aplicacao para success_url/cancel_url
APP_BASE_URL=http://localhost:3000
