# Firebase Cloud Functions (webhookStripe)
# Chave secreta da API Stripe
STRIPE_SECRET_KEY=

# Segredo do endpoint de webhook (comeca com whsec_)
STRIPE_WEBHOOK_SECRET=

# Observacao:
# Nao precisa FIREBASE_CLIENT_EMAIL/FIREBASE_PRIVATE_KEY aqui,
# porque a Cloud Function usa a credencial padrao do proprio projeto Firebase.
