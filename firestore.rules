rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────────────────────────
    // Ping de conexão (Home.js -> testFirebase). Apenas usuários
    // autenticados (anônimos inclusive) podem escrever/ler o doc 'ping'.
    // ──────────────────────────────────────────────────────────────────
    match /app_test/{docId} {
      allow read, write: if request.auth != null;
    }

    // Empresas publicas com campos basicos.
    match /empresas/{cnpj} {
      allow read: if true;

      // Escrita da empresa: apenas backend/admin.
      allow write: if false;
    }

    // Cadastro de empresas (formulário CompanyRegister): leitura pública,
    // escrita restrita a usuários autenticados.
    match /companies/{companyId} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // Cache de buscas por nome (op=search do /api/cnpj). Apenas o backend
    // (Admin SDK) grava; leitura nunca acontece pelo cliente (a busca passa
    // pela API), então fechamos completamente.
    match /companies_search_cache/{term} {
      allow read, write: if false;
    }

    // Dados sensiveis separados para permitir controle por regra.
    // Estrutura sugerida:
    // /empresas_private/{cnpj} {
    //   detalhes_rh: ...,
    //   salarios_detalhados: ...,
    //   relatorios_ia: ...
    // }
    match /empresas_private/{cnpj} {
      allow read: if
        exists(/databases/$(database)/documents/empresas/$(cnpj)) &&
        get(/databases/$(database)/documents/empresas/$(cnpj)).data.isPremium == true;

      allow write: if false;
    }

    // Avaliações de empresas.
    match /reviews/{reviewId} {
      // Qualquer pessoa pode ler avaliações.
      allow read: if true;

      // Criação: requer usuário autenticado (mínimo anônimo).
      // O cliente NÃO pode marcar a review como verificada — esses
      // campos são preenchidos apenas pelo backend (Admin SDK) via
      // /api/verify-review-linkedin.
      allow create: if request.auth != null
        && (!('isVerifiedLinkedIn' in request.resource.data)
            || request.resource.data.isVerifiedLinkedIn == false)
        && !('verificationSource' in request.resource.data)
        && !('verifiedAt' in request.resource.data);

      // Edição: apenas o autor original pode editar, identificado pelo uid do Firebase Auth.
      // Campos de identidade (uid, pseudonym, company, companySlug, createdAt) não podem ser alterados.
      // Campos de verificação só podem ser preservados — nunca alterados pelo cliente.
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.pseudonym == resource.data.pseudonym
        && request.resource.data.company == resource.data.company
        && request.resource.data.companySlug == resource.data.companySlug
        && request.resource.data.get('isVerifiedLinkedIn', false)
            == resource.data.get('isVerifiedLinkedIn', false)
        && request.resource.data.get('verificationSource', '')
            == resource.data.get('verificationSource', '')
        && request.resource.data.get('verifiedAt', '')
            == resource.data.get('verifiedAt', '');

      // Exclusão: apenas o autor original pode apagar.
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // Avaliações de processo seletivo (usuário NÃO contratado).
    // Mesmo padrão das reviews, em coleção separada.
    match /selectionProcessReviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // Avaliações B2B entre empresas (EvaluatePartner). O documento é
    // identificado pelo CNPJ avaliador; só o autor autenticado cria.
    match /companyReviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Reações a avaliações (uma por usuário por review).
    match /reviewReactions/{reactionId} {
      allow read: if true;
      allow create: if request.auth != null;
      // Reações são imutáveis (idempotência garantida no cliente).
      allow update, delete: if false;
    }

    // Notificações de atividade (reações/respostas a comentários).
    // - Criação: qualquer usuário autenticado pode notificar OUTRO usuário,
    //   desde que o destinatário (toUid) seja informado e o doc nasça não-lido.
    // - Leitura/atualização: apenas o destinatário (marcar como lido).
    match /notifications/{notificationId} {
      allow read: if request.auth != null
                  && resource.data.toUid == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.toUid is string
                    && request.resource.data.toUid.size() > 0
                    && request.resource.data.read == false;
      allow update: if request.auth != null
                    && resource.data.toUid == request.auth.uid
                    && request.resource.data.toUid == resource.data.toUid;
      allow delete: if false;
    }

    // Reações em comentários gerais (CompanyDetails).
    match /commentReactions/{reactionId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Reações em comentários por item da empresa.
    match /item_comment_reactions/{reactionId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Denúncias de conteúdo (CompanyDetails -> content_reports).
    // Qualquer usuário autenticado pode criar; sem update/delete pelo cliente.
    match /content_reports/{reportId} {
      allow read: if false;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Pedidos de suporte de empresas (EmpresaDashboard).
    match /supportRequests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // Lista de espera para empresas (CompanyProfile).
    match /waitlist_empresa/{entryId} {
      allow read: if false;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Catálogo de profissões (read público, escrita só admin/backend).
    match /professions/{professionId} {
      allow read: if true;
      allow write: if false;
    }

    // Catálogo de serviços de RH (BusinessDashboard).
    match /servicosRH/{servicoId} {
      allow read: if true;
      allow write: if false;
    }

    // Apoiadores antigos / dashboard administrativo (supporters).
    // Leitura pública para listagens; escrita restrita ao próprio dono.
    match /supporters/{supporterId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Perfis de trabalhador profissional (WorkerProfessionalContactSettings).
    // O documento é identificado pelo profileId do usuário.
    match /profiles/{profileId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Comentários de discussão por item da empresa.
    match /item_comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Threads de reações/respostas por entrada de item.
    match /item_comment_threads/{threadId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Comentários gerais por empresa.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null;
    }

    // Consultores parceiros.
    match /consultores/{consultorId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Prestadores de serviços corporativos.
    match /prestadores/{prestadorId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Perfis de usuário. Leitura liberada a QUALQUER usuário autenticado, pois
    // o perfil público do trabalhador (/perfil/:id) precisa ser visível a
    // outros usuários logados (especialistas, apoiadores, etc.) — não apenas
    // ao dono. Escrita (create/update/delete) continua restrita ao próprio
    // dono, mesmo quando o id do documento é alternativo (ex.: "email:foo@bar")
    // e difere do Firebase Auth UID. A propriedade é confirmada por QUALQUER
    // uma das provas abaixo, para cobrir docs por uid e docs por email:
    //   1) request.auth.uid == userId                (id do doc é o uid);
    //   2) resource.data.uid == request.auth.uid      (campo uid grava o dono);
    //   3) resource.data.email == request.auth.token.email (doc por e-mail).
    // Sem a leitura aberta, o perfil público de OUTRO usuário exibia
    // "precisa estar logado" para quem não fosse o dono.
    match /users/{userId} {
      function ownsUserDoc() {
        return request.auth != null
          && (request.auth.uid == userId
              || resource.data.uid == request.auth.uid
              || (request.auth.token.email != null
                  && resource.data.email == request.auth.token.email));
      }
      function ownsNewUserDoc() {
        return request.auth != null
          && (request.auth.uid == userId
              || request.resource.data.uid == request.auth.uid
              || (request.auth.token.email != null
                  && request.resource.data.email == request.auth.token.email));
      }
      allow read: if request.auth != null;
      allow create: if ownsNewUserDoc();
      allow update: if ownsUserDoc();
      allow delete: if ownsUserDoc();

      // Contatos de especialistas liberados após pagamento aprovado de
      // consulta. Gravados apenas pelo backend (Admin SDK, que ignora estas
      // regras); o cliente apenas lê os próprios contatos liberados. A
      // subcoleção é sempre lida sob o UID do Auth (users/{uid}/...).
      match /releasedContacts/{contactId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // Dados pessoais do trabalhador compartilhados com o especialista que
    // aceitar o seu caso (CPF, RG, endereço, estado civil, etc.). O documento
    // privado completo segue em /users/{uid}; aqui guardamos apenas o subset
    // necessário ao atendimento. Escrita restrita ao próprio dono; leitura
    // liberada a qualquer usuário autenticado (o especialista só conhece o
    // uid via uma conversa/caso aceito — uids não são enumeráveis).
    match /clientProfiles/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Apoiadores (coleção unificada).
    match /apoiadores/{apoiadorId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;

      // Avaliações de apoiadores.
      match /avaliacoes/{avaliacaoId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if false;
        allow delete: if false;
      }

      // Casos ativos do especialista (clientes aceitos no chat).
      // Apenas o PRÓPRIO especialista dono do perfil pode ler/escrever os
      // seus casos. A identidade é confirmada de duas formas (qualquer uma
      // basta), para cobrir tanto os docs novos (id = "apoiador_<...>", com
      // campo `uid` = Auth uid) quanto os legados/seed (id = Auth uid):
      //   1) request.auth.uid == apoiadorId  (doc id é o próprio uid); ou
      //   2) request.auth.uid == apoiador.data.uid  (campo uid do doc).
      match /cases/{caseId} {
        function isCaseOwner() {
          return request.auth != null
            && (request.auth.uid == apoiadorId
                || request.auth.uid ==
                   get(/databases/$(database)/documents/apoiadores/$(apoiadorId)).data.uid);
        }
        allow read, create, update: if isCaseOwner();
        allow delete: if false;
      }
    }

    // Profissionais de Apoio (userType = 'supportProfessional').
    // Perfil público de leitura aberta; escrita apenas pelo dono autenticado.
    match /supportProfessionals/{profId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == profId;
      allow update: if request.auth != null && request.auth.uid == profId;
      allow delete: if request.auth != null && request.auth.uid == profId;
    }

    // Pedidos de contato entre Apoiadores Premium e Trabalhadores.
    // Privacidade: apenas o remetente (from) e o destinatário (to)
    // podem ler. Atualização: somente o destinatário pode responder.
    match /contactRequests/{requestId} {
      allow read: if request.auth != null
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.message is string;
      allow update: if request.auth != null
        && resource.data.toUid == request.auth.uid
        && request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toUid == resource.data.toUid;
      allow delete: if false;
    }

    // Pedidos de contato entre Empresas Premium e Apoiadores Premium.
    // Privacidade: apenas o remetente (fromUid - empresa) e o
    // destinatário (toApoiadorUid - apoiador) podem ler. Atualização:
    // somente o apoiador destinatário pode responder.
    match /contactRequestsApoiador/{requestId} {
      // Identifica o especialista destinatário do pedido. Confirma por
      // QUALQUER uma das provas (cobre pedidos novos e legados em que
      // `toApoiadorUid` ficou vazio na criação):
      //   1) toApoiadorUid == auth.uid  (uid gravado no pedido); ou
      //   2) apoiadores/{toApoiadorId}.uid == auth.uid  (dono do perfil).
      function isRequestSpecialist(reqData) {
        return request.auth != null
          && (reqData.toApoiadorUid == request.auth.uid
              || (reqData.toApoiadorId is string
                  && exists(/databases/$(database)/documents/apoiadores/$(reqData.toApoiadorId))
                  && get(/databases/$(database)/documents/apoiadores/$(reqData.toApoiadorId)).data.uid == request.auth.uid));
      }
      allow read: if request.auth != null
        && (resource.data.fromUid == request.auth.uid
            || isRequestSpecialist(resource.data));
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toApoiadorId is string
        && request.resource.data.message is string;
      // Somente o especialista destinatário pode responder/aceitar o pedido.
      // Não pode alterar o solicitante nem o destinatário do pedido (mas pode
      // preencher `toApoiadorUid` — backfill do próprio uid — ao aceitar).
      allow update: if isRequestSpecialist(resource.data)
        && request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toApoiadorId == resource.data.toApoiadorId;
      allow delete: if false;
    }

    // ──────────────────────────────────────────────────────────────────
    // Casos (atendimentos) — coleção top-level trabalhador × especialista.
    //
    // Cada caso pertence a um TRABALHADOR e a um ESPECIALISTA. Ambos podem
    // ler/atualizar; a identidade do especialista é confirmada pelo UID do
    // Auth gravado em `especialistaUid` (o `especialistaId` é o id do doc
    // /apoiadores/{id}, que pode diferir do UID). Ninguém pode apagar.
    // ──────────────────────────────────────────────────────────────────
    match /casos/{casoId} {
      function ownsCaso(data) {
        return request.auth != null
          && (data.trabalhadorId == request.auth.uid
              || data.especialistaUid == request.auth.uid);
      }
      allow read: if ownsCaso(resource.data);
      allow create: if ownsCaso(request.resource.data);
      allow update: if ownsCaso(resource.data)
        && request.resource.data.trabalhadorId == resource.data.trabalhadorId
        && request.resource.data.especialistaId == resource.data.especialistaId;
      allow delete: if false;
    }

    // ──────────────────────────────────────────────────────────────────
    // Chat interno trabalhador × especialista.
    //
    // PRIVACIDADE: cada conversa é EXCLUSIVA do par (trabalhador,
    // especialista). O documento da conversa guarda os UIDs dos
    // participantes em `participants` (array). Somente esses UIDs podem
    // ler/escrever a conversa e suas mensagens — assim um trabalhador
    // nunca enxerga as mensagens de outro trabalhador com o mesmo
    // especialista, e vice-versa.
    //
    // OBS.: hoje o chat é um MVP em localStorage; estas regras já deixam o
    // modelo de privacidade pronto para quando as mensagens migrarem para
    // o Firestore (estrutura /conversations/{id}/messages/{msgId}).
    // ──────────────────────────────────────────────────────────────────
    match /conversations/{conversationId} {
      // Leitura: um participante pode ler a conversa. Quando o documento
      // AINDA NÃO existe (resource == null), permitimos o get para que o
      // cliente consiga detectar a inexistência e então CRIAR a conversa
      // (ensureConversation faz getDoc → setDoc). Sem esta cláusula, o get
      // de um doc inexistente é negado e a conversa nunca é criada.
      allow read: if request.auth != null
        && (resource == null
            || request.auth.uid in resource.data.participants);
      allow create: if request.auth != null
        && request.resource.data.participants is list
        && request.auth.uid in request.resource.data.participants;
      // Os participantes não podem ser alterados após a criação.
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in
             get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        // Só um participante pode enviar, e a mensagem deve declarar o
        // próprio remetente (senderUid == auth.uid).
        allow create: if request.auth != null
          && request.auth.uid in
             get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
          && request.resource.data.senderUid == request.auth.uid;
        allow update, delete: if false;
      }

      // Documentos trocados na conversa (trabalhador → especialista e
      // vice-versa). Subcoleção /conversations/{id}/documents/{docId}.
      // Apenas participantes leem; quem cria precisa declarar-se como
      // remetente (senderId == auth.uid). Metadados imutáveis.
      match /documents/{documentId} {
        allow read: if request.auth != null
          && request.auth.uid in
             get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if request.auth != null
          && request.auth.uid in
             get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
          && request.resource.data.senderId == request.auth.uid;
        allow update: if false;
        // Apenas o remetente pode apagar o próprio documento.
        allow delete: if request.auth != null
          && resource.data.senderId == request.auth.uid;
      }
    }

    // Funil de cadastro: registra quem entrou na página /pseudonym
    // e quem completou. Documento por uid do Firebase Auth (anônimo ou não).
    // Leitura/listagem só pelo backend admin; cada usuário pode criar/atualizar
    // o próprio registro para sinalizar início e conclusão.
    match /cadastros_iniciados/{userId} {
      allow read, list: if false;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Consultas (pontuais/avulsas e agendadas) entre Trabalhadores e
    // Especialistas (apoiadores). Solicitadas pelo trabalhador; aceitas
    // ou recusadas pelo apoiador.
    //
    // Campos obrigatórios na criação:
    //   workerId       = request.auth.uid (solicitante)
    //   apoiadorId     = id do apoiador (string)
    //   status         = "pending"
    //   tipo / type    = "avulsa" | "acompanhamento" | ...
    match /consultas/{consultaId} {
      // Apenas o trabalhador solicitante (workerId) e o apoiador
      // destinatário (apoiadorId == auth.uid) podem ler.
      allow read: if request.auth != null
        && (resource.data.workerId == request.auth.uid
            || resource.data.apoiadorId == request.auth.uid);

      // Criação: o trabalhador autenticado registra a solicitação.
      allow create: if request.auth != null
        && request.resource.data.workerId == request.auth.uid
        && request.resource.data.apoiadorId is string
        && request.resource.data.status == "pending";

      // Atualização: o apoiador destinatário pode aceitar/recusar
      // e marcar como lida; o trabalhador pode cancelar a solicitação.
      // Os identificadores (workerId/apoiadorId) não podem mudar.
      allow update: if request.auth != null
        && request.resource.data.workerId == resource.data.workerId
        && request.resource.data.apoiadorId == resource.data.apoiadorId
        && (resource.data.apoiadorId == request.auth.uid
            || resource.data.workerId == request.auth.uid);

      allow delete: if false;
    }

    // Comissões "Ad Exitum" devidas à plataforma.
    //
    // Registradas pelo especialista (advogado) ao informar o valor total do
    // processo e o valor recebido pelo trabalhador. A comissão (10% sobre o
    // valor recebido) fica como `status: "pending"` até a quitação.
    //
    // SEGURANÇA: somente o especialista autenticado associado ao processo
    // pode criar o registro (specialistUid == auth.uid). Os valores precisam
    // ser numéricos e positivos, e a comissão precisa bater com 10% dos
    // honorários do advogado (feeValue), com tolerância de 1 centavo para
    // arredondamento. A leitura é liberada ao especialista e ao trabalhador
    // vinculado (para exibir os valores no perfil do trabalhador). Registros
    // são imutáveis pelo cliente — quitação/ajuste ficam a cargo do backend.
    match /commissions/{commissionId} {
      allow read: if request.auth != null
        && (resource.data.specialistUid == request.auth.uid
            || resource.data.workerId == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.specialistUid == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.totalProcessValue is number
        && request.resource.data.totalProcessValue > 0
        && request.resource.data.receivedValue is number
        && request.resource.data.receivedValue >= 0
        && request.resource.data.feeValue is number
        && request.resource.data.feeValue > 0
        && request.resource.data.commissionValue is number
        && request.resource.data.commissionValue
             >= request.resource.data.feeValue * 0.1 - 0.01
        && request.resource.data.commissionValue
             <= request.resource.data.feeValue * 0.1 + 0.01;
      allow update, delete: if false;
    }
  }
}