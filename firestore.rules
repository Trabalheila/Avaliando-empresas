rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Empresas publicas com campos basicos.
    match /empresas/{cnpj} {
      allow read: if true;

      // Escrita da empresa: apenas backend/admin.
      allow write: if false;
    }

    // Cadastro de empresas (formulário CompanyRegister): leitura pública,
    // escrita restrita a usuários autenticados.
    match /companies/{companyId} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // Dados sensiveis separados para permitir controle por regra.
    // Estrutura sugerida:
    // /empresas_private/{cnpj} {
    //   detalhes_rh: ...,
    //   salarios_detalhados: ...,
    //   relatorios_ia: ...
    // }
    match /empresas_private/{cnpj} {
      allow read: if
        exists(/databases/$(database)/documents/empresas/$(cnpj)) &&
        get(/databases/$(database)/documents/empresas/$(cnpj)).data.isPremium == true;

      allow write: if false;
    }

    // Avaliações de empresas.
    match /reviews/{reviewId} {
      // Qualquer pessoa pode ler avaliações.
      allow read: if true;

      // Criação: requer usuário autenticado (mínimo anônimo).
      allow create: if request.auth != null;

      // Edição: apenas o autor original pode editar, identificado pelo uid do Firebase Auth.
      // Campos de identidade (uid, pseudonym, company, companySlug, createdAt) não podem ser alterados.
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.pseudonym == resource.data.pseudonym
        && request.resource.data.company == resource.data.company
        && request.resource.data.companySlug == resource.data.companySlug;

      // Exclusão: apenas o autor original pode apagar.
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // Reações a avaliações (uma por usuário por review).
    match /reviewReactions/{reactionId} {
      allow read: if true;
      allow create: if request.auth != null;
      // Reações são imutáveis (idempotência garantida no cliente).
      allow update, delete: if false;
    }

    // Comentários de discussão por item da empresa.
    match /item_comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Threads de reações/respostas por entrada de item.
    match /item_comment_threads/{threadId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Comentários gerais por empresa.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null;
    }

    // Consultores parceiros.
    match /consultores/{consultorId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Prestadores de serviços corporativos.
    match /prestadores/{prestadorId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Perfis de usuário: apenas o próprio dono pode ler e escrever.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Apoiadores (coleção unificada).
    match /apoiadores/{apoiadorId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;

      // Avaliações de apoiadores.
      match /avaliacoes/{avaliacaoId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if false;
        allow delete: if false;
      }
    }

    // Profissionais de Apoio (userType = 'supportProfessional').
    // Perfil público de leitura aberta; escrita apenas pelo dono autenticado.
    match /supportProfessionals/{profId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == profId;
      allow update: if request.auth != null && request.auth.uid == profId;
      allow delete: if request.auth != null && request.auth.uid == profId;
    }

    // Pedidos de contato entre Apoiadores Premium e Trabalhadores.
    // Privacidade: apenas o remetente (from) e o destinatário (to)
    // podem ler. Atualização: somente o destinatário pode responder.
    match /contactRequests/{requestId} {
      allow read: if request.auth != null
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.message is string;
      allow update: if request.auth != null
        && resource.data.toUid == request.auth.uid
        && request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toUid == resource.data.toUid;
      allow delete: if false;
    }

    // Pedidos de contato entre Empresas Premium e Apoiadores Premium.
    // Privacidade: apenas o remetente (fromUid - empresa) e o
    // destinatário (toApoiadorUid - apoiador) podem ler. Atualização:
    // somente o apoiador destinatário pode responder.
    match /contactRequestsApoiador/{requestId} {
      allow read: if request.auth != null
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toApoiadorUid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toApoiadorId is string
        && request.resource.data.message is string;
      allow update: if request.auth != null
        && resource.data.toApoiadorUid == request.auth.uid
        && request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toApoiadorId == resource.data.toApoiadorId;
      allow delete: if false;
    }

    // Funil de cadastro: registra quem entrou na página /pseudonym
    // e quem completou. Documento por uid do Firebase Auth (anônimo ou não).
    // Leitura/listagem só pelo backend admin; cada usuário pode criar/atualizar
    // o próprio registro para sinalizar início e conclusão.
    match /cadastros_iniciados/{userId} {
      allow read, list: if false;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }
  }
}