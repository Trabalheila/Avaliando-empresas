{
  "buildCommand": "react-scripts build",
  "installCommand": "npm install --legacy-peer-deps",
  "outputDirectory": "build",
  "functions": {
    "api/create-checkout-session.js": {
      "maxDuration": 30
    },
    "api/admin.js": {
      "maxDuration": 30
    },
    "api/cnpj.js": {
      "maxDuration": 30
    },
    "api/webhook.js": {
      "maxDuration": 30
    },
    "api/send-confirmation.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/confirm-company", "destination": "/api/send-confirmation" },
    { "source": "/api/verify-email", "destination": "/api/send-verification-email" },
    { "source": "/api/send-contact-request-apoiador", "destination": "/api/send-contact-request" },
    { "source": "/api/send-receipt", "destination": "/api/send-contact-request?op=receipt" },
    { "source": "/api/chat-with-gemini", "destination": "/api/chat-gemini" },
    { "source": "/api/parse-cv", "destination": "/api/chat-gemini?op=parse-cv" },
    { "source": "/api/verify-review-linkedin", "destination": "/api/admin?op=verify-review-linkedin" },
    { "source": "/api/company-logo", "destination": "/api/cnpj?op=company-logo" },
    { "source": "/api/payments/create-charge", "destination": "/api/payments?op=create-charge" },
    { "source": "/api/payments/mercado-pago-checkout", "destination": "/api/payments?op=mp-checkout" },
    { "source": "/api/payments/mp-checkout", "destination": "/api/payments?op=mp-checkout" },
    { "source": "/api/payments/webhook", "destination": "/api/payments?op=webhook" },
    { "source": "/api/payments/mp-webhook", "destination": "/api/payments?op=webhook" },
    { "source": "/api/payments/release-funds", "destination": "/api/payments?op=release-funds" },
    { "source": "/(.*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com https://ssl.google-analytics.com https://*.mercadopago.com https://*.mercadopago.com.br https://*.mercadolibre.com https://*.mlstatic.com; frame-src 'self' https://*.mercadopago.com https://*.mercadopago.com.br https://*.mercadolibre.com https://*.mlstatic.com; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: blob: https:; font-src 'self' data: https:; connect-src 'self' https: wss:;"
        }
      ]
    }
  ]
}

